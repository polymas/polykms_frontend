# 环境配置
# 可选值: test, production
# 默认为 test（测试环境）
VITE_ENVIRONMENT=test

# API基础URL（可选）
# 如果设置了此值，将优先使用此值
# 如果不设置，将根据 VITE_ENVIRONMENT 自动选择：
#   - test: http://localhost:8866 (开发模式走vite代理)
#   - production: https://api.polyking.site
# VITE_API_BASE_URL=

# 客户看板「每日利润」曲线数据源（poly_activity 钱包活动缓存后端，可选）
# 开发模式(npm run dev) 不设置时默认: http://localhost:7001；生产默认: https://www.polyking.site/activity
# VITE_ACTIVITY_API_BASE_URL=http://localhost:7001
